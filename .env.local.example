# Polygon.io (free tier - https://polygon.io)
POLYGON_API_KEY=your_polygon_key_here

# Anthropic (jury LLM calls)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Serper.dev (news enrichment)
SERPER_API_KEY=your_serper_key_here

# Upstash Redis — Vercel Marketplace → Upstash Redis → your store → .env.local tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron auth — generate with: openssl rand -hex 32
# Add this same value to your Vercel project env vars so the cron is authenticated
CRON_SECRET=
